---
import Header from '@/components/Header.astro';
import LocaleRedirect from '@/components/LocaleRedirect.astro';
import { defaultLocale, getSiteContent } from '@/data/site-content';
import type { Locale, SiteContent } from '@/data/site-content.schema';
import { buildPageSeo } from '@/lib/seo';
import SeoHead from '@/components/seo/SeoHead.astro';
import ThemeBootstrap from '@/components/ThemeBootstrap.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import ScrollToTopButton from '@/components/ScrollToTopButton.astro';
import '@/index.css';

import interLatin400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import newsreaderLatin300 from '@fontsource/newsreader/files/newsreader-latin-300-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  image?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article';
  locale?: Locale;
  content?: SiteContent;
  enableLocaleRedirect?: boolean;
  publishedTime?: Date;
  tags?: string[];
  updatedTime?: Date;
  alternatePaths?: Partial<Record<Locale, string>>;
}

const {
  locale = defaultLocale, content = getSiteContent(locale),
  title = content.seo.title, description = content.seo.description,
  currentPath = Astro.url.pathname, image, noindex = false,
  ogType = 'website', enableLocaleRedirect = false,
  publishedTime, tags, updatedTime, alternatePaths,
} = Astro.props;

const pageSeo = buildPageSeo({ baseUrl: Astro.site ?? Astro.url.origin, content, currentPath, description, image, locale, noindex, ogType, publishedTime, tags, title, updatedTime, alternatePaths });
---

<!doctype html>
<html lang={locale}>
  <head>
    <link rel="preload" href={interLatin400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={newsreaderLatin300} as="font" type="font/woff2" crossorigin />
    <SeoHead content={content} title={title} description={description} ogType={ogType} pageSeo={pageSeo} publishedTime={publishedTime} updatedTime={updatedTime} tags={tags} />
    <ThemeBootstrap />
    {enableLocaleRedirect ? <LocaleRedirect /> : null}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="min-h-screen">
      <Header content={content} locale={locale} currentPath={currentPath} />
      <main id="main-content" tabindex="-1"><slot /></main>
      <SiteFooter content={content} locale={locale} />
      <ScrollToTopButton />
    </div>
  </body>
</html>
