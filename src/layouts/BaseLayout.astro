---
import Header from '@/components/Header.astro';
import LocaleRedirect from '@/components/LocaleRedirect.astro';
import { defaultLocale, getAlternateLocale, getLocalePath, getSiteContent } from '@/data/site-content';
import type { Locale, SiteContent } from '@/data/site-content.schema';
import { hasPublicResume } from '@/lib/resume';
import '@/index.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  ogType?: 'website' | 'article';
  locale?: Locale;
  content?: SiteContent;
  enableLocaleRedirect?: boolean;
}

const {
  locale = defaultLocale,
  content = getSiteContent(locale),
  title = content.seo.title,
  description = content.seo.description,
  currentPath = Astro.url.pathname,
  ogType = 'website',
  enableLocaleRedirect = false,
} = Astro.props;

const canonicalUrl = new URL(currentPath, Astro.site ?? Astro.url.origin).toString();
const alternateLocale = getAlternateLocale(locale);
const alternateUrl = new URL(getLocalePath(alternateLocale), Astro.site ?? Astro.url.origin).toString();
const defaultUrl = new URL(getLocalePath(defaultLocale), Astro.site ?? Astro.url.origin).toString();
const resumeAvailable = hasPublicResume();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLocale} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={defaultUrl} />
    <link rel="alternate" type="application/rss+xml" title="Blog RSS" href="/rss.xml" />
    <script is:inline>
      (() => {
        const key = 'theme';
        const stored = localStorage.getItem(key);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored === 'light' || stored === 'dark' ? stored : prefersDark ? 'dark' : 'light';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    {enableLocaleRedirect ? <LocaleRedirect /> : null}
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="min-h-screen">
      <Header content={content} locale={locale} currentPath={currentPath} resumeAvailable={resumeAvailable} />

      <main id="main-content" tabindex="-1">
        <slot />
      </main>

      <footer class="mt-32 border-t border-border py-12">
        <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 md:flex-row md:items-center md:justify-between md:px-8">
          <div>
            <p class="font-sans text-xs font-semibold uppercase tracking-[0.1em] text-text">
              © {new Date().getFullYear()} DESIGN MONOGRAPH. ALL RIGHTS RESERVED.
            </p>
          </div>
          <div class="flex gap-6">
            <a href="https://github.com" class="font-sans text-xs font-semibold uppercase tracking-[0.1em] text-text-muted transition-colors hover:text-text">GITHUB</a>
            <a href="https://linkedin.com" class="font-sans text-xs font-semibold uppercase tracking-[0.1em] text-text-muted transition-colors hover:text-text">LINKEDIN</a>
            <a href="/rss.xml" class="font-sans text-xs font-semibold uppercase tracking-[0.1em] text-text-muted transition-colors hover:text-text">RSS</a>
          </div>
        </div>
      </footer>
    </div>

    <script is:inline define:vars={{ defaultLocale }}>
      const localeLinks = document.querySelectorAll('[data-locale-link]');
      localeLinks.forEach((link) => {
        link.addEventListener('click', () => {
          localStorage.setItem('locale', link.dataset.locale || defaultLocale);
        });
      });

      const applyThemeIcon = () => {
        const isDark = document.documentElement.classList.contains('dark');
        document.querySelectorAll('[data-theme-icon="dark"]').forEach((icon) => icon.toggleAttribute('hidden', isDark));
        document.querySelectorAll('[data-theme-icon="light"]').forEach((icon) => icon.toggleAttribute('hidden', !isDark));
      };

      document.querySelectorAll('[data-theme-toggle]').forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const nextTheme = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
          document.documentElement.classList.toggle('dark', nextTheme === 'dark');
          localStorage.setItem('theme', nextTheme);
          applyThemeIcon();
        });
      });

      applyThemeIcon();
    </script>
  </body>
</html>
