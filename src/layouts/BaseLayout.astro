---
import Header from '@/components/Header.astro';
import LocaleRedirect from '@/components/LocaleRedirect.astro';
import Icon from '@/components/Icon.astro';
import { defaultLocale, getAlternateLocale, getLocalePath, getSiteContent } from '@/data/site-content';
import type { Locale, SiteContent } from '@/data/site-content.schema';
import { hasPublicResume } from '@/lib/resume';
import '@/index.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  ogType?: 'website' | 'article';
  locale?: Locale;
  content?: SiteContent;
  enableLocaleRedirect?: boolean;
}

const {
  locale = defaultLocale,
  content = getSiteContent(locale),
  title = content.seo.title,
  description = content.seo.description,
  currentPath = Astro.url.pathname,
  ogType = 'website',
  enableLocaleRedirect = false,
} = Astro.props;

const canonicalUrl = new URL(currentPath, Astro.site ?? Astro.url.origin).toString();
const alternateLocale = getAlternateLocale(locale);
const alternateUrl = new URL(getLocalePath(alternateLocale), Astro.site ?? Astro.url.origin).toString();
const defaultUrl = new URL(getLocalePath(defaultLocale), Astro.site ?? Astro.url.origin).toString();
const socialIconFor = { github: 'github', linkedin: 'linkedin', mail: 'mail' } as const;
const resumeAvailable = hasPublicResume();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLocale} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={defaultUrl} />
    <link rel="alternate" type="application/rss+xml" title="Blog RSS" href="/rss.xml" />
    <script is:inline>
      (() => {
        const key = 'theme';
        const stored = localStorage.getItem(key);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored === 'light' || stored === 'dark' ? stored : prefersDark ? 'dark' : 'light';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
    {enableLocaleRedirect ? <LocaleRedirect /> : null}
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="min-h-screen">
      <Header content={content} locale={locale} currentPath={currentPath} resumeAvailable={resumeAvailable} />

      <main id="main-content" tabindex="-1">
        <slot />
      </main>

      <footer class="border-t border-border px-4 py-10">
        <div class="mx-auto flex max-w-6xl flex-col gap-6 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted">
              {new Date().getFullYear()} {content.hero.name}
            </p>
            <p class="mt-2 text-sm text-text-muted">{content.seo.footerNote}</p>
          </div>
          <div class="flex gap-3">
            {content.hero.socialLinks.map(({ platform, href, label }) => (
              <a href={href} aria-label={label} class="social-link">
                <Icon name={socialIconFor[platform]} size={18} />
              </a>
            ))}
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
