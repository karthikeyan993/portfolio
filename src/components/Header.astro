---
import { getAlternateLocale, getLocalePath } from '@/data/site-content';
import type { Locale, SiteContent } from '@/data/site-content.schema';
import Icon from '@/components/Icon.astro';

interface Props {
  content: SiteContent;
  locale: Locale;
  currentPath: string;
  resumeAvailable?: boolean;
}

const { locale, currentPath } = Astro.props;
const isHome = currentPath === '/' || currentPath === '/de/';
const alternateLocale = getAlternateLocale(locale);
const alternateUrl = getLocalePath(alternateLocale);
---

<nav class="flex justify-end items-center max-w-7xl mx-auto px-8 md:px-16 py-10 w-full">
  <div class="flex items-center gap-6 md:gap-12">
    <div class="flex gap-6 md:gap-8 items-center font-heading text-lg tracking-tight">
      <a href="/" class={`pb-0.5 transition-all duration-300 ease-in-out ${isHome ? 'text-text border-b border-text italic opacity-70' : 'text-text-muted hover:text-text'}`}>
        Home
      </a>
      <a href="/blog/" class={`pb-0.5 transition-all duration-300 ease-in-out ${!isHome ? 'text-text border-b border-text italic opacity-70' : 'text-text-muted hover:text-text'}`}>
        Blog
      </a>
    </div>

    <div class="flex items-center gap-6 border-l border-border pl-6">
      <a
        href={alternateUrl}
        class="label-caps text-text-muted hover:text-text transition-colors"
        data-locale-link
        data-locale={alternateLocale}
      >
        {alternateLocale.toUpperCase()}
      </a>
      <button 
        type="button" 
        class="text-text-muted hover:text-brand-primary transition-colors flex items-center justify-center p-1" 
        data-theme-toggle
        aria-label="Toggle theme"
      >
        <span data-theme-icon="light"><Icon name="moon" size={20} /></span>
        <span data-theme-icon="dark" hidden><Icon name="sun" size={20} /></span>
      </button>
    </div>
  </div>
</nav>
