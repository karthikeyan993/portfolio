---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-12 max-w-4xl">
  {eyebrow ? <p class="eyebrow mb-4">{eyebrow}</p> : null}
  <h2 class="headline-xl text-brand-primary">
    {title}
  </h2>
  {description ? <p class="mt-6 max-w-2xl body-lg text-text-muted">{description}</p> : null}
</div>
