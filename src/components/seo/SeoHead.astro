---
import type { PageSeo } from '@/lib/seo';
import type { SiteContent } from '@/data/site-content.schema';

interface Props {
  content: SiteContent;
  title: string;
  description: string;
  ogType: 'website' | 'article';
  pageSeo: PageSeo;
  publishedTime?: Date;
  updatedTime?: Date;
  tags?: string[];
}

const { content, title, description, ogType, pageSeo, publishedTime, updatedTime, tags } = Astro.props;
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="author" content={content.seo.author} />
<meta name="keywords" content={content.seo.keywords.join(', ')} />
<meta name="robots" content={pageSeo.robots} />
<meta name="theme-color" content="#faf9f7" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#11131a" media="(prefers-color-scheme: dark)" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={content.seo.siteName} />
<meta property="og:url" content={pageSeo.canonicalUrl} />
<meta property="og:locale" content={pageSeo.localeCode} />
<meta property="og:image" content={pageSeo.imageUrl} />
<meta property="og:image:alt" content={content.seo.siteName} />
{ogType === 'article' && publishedTime ? <meta property="article:published_time" content={publishedTime.toISOString()} /> : null}
{ogType === 'article' && updatedTime ? <meta property="article:modified_time" content={updatedTime.toISOString()} /> : null}
{ogType === 'article' && tags ? tags.map((tag) => <meta property="article:tag" content={tag} />) : null}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={pageSeo.imageUrl} />
<link rel="canonical" href={pageSeo.canonicalUrl} />
{pageSeo.alternateLinks.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
<link rel="alternate" type="application/rss+xml" title={`${content.common.blogLabel} RSS`} href={content.locale === 'de' ? '/de/rss.xml' : '/rss.xml'} />
<script type="application/ld+json" set:html={JSON.stringify(pageSeo.structuredData)} />
<title>{title}</title>
