---
import BlogCard from '@/components/BlogCard.astro';
import ButtonLink from '@/components/ButtonLink.astro';
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import type { BlogPost } from '@/lib/blog';
import type { SiteContent } from '@/data/site-content.schema';

interface Props {
  posts: BlogPost[];
  content: SiteContent;
}

const { posts, content } = Astro.props;
---

<Section id="writing" tinted>
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <SectionHeading eyebrow={content.writing.eyebrow} title={content.writing.title} description={content.writing.description} />
    <ButtonLink href="/blog/" variant="secondary" size="sm" class="mb-10 w-max">{content.writing.readAllLabel}</ButtonLink>
  </div>

  <div class="grid gap-4">
    {posts.map((post) => (
      <BlogCard post={post} readLabel={content.common.readPostLabel} readTimeSuffix={content.common.readTimeSuffix} />
    ))}
  </div>
</Section>
