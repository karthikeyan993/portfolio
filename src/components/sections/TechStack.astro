---
import type { TechStackContent } from '@/data/site-content.schema';
import Section from '@/components/Section.astro';

interface Props {
  content: TechStackContent;
  tinted?: boolean;
}

const { content } = Astro.props;
const techs = content.categories.flatMap((category) => category.techs).filter((tech) => tech.trim());
---

<Section id="tech-stack" containerClass="max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-16">
      <div class="md:col-span-4 md:pt-4">
        <h2 class="headline-md text-brand-primary">{content.eyebrow}</h2>
      </div>
      <div class="md:col-span-8 md:col-start-5 pt-4 md:pt-8">
        <div class="flex flex-wrap gap-3">
          {techs.map((tech) => (
            <span class="label-caps text-text-muted border border-border px-4 py-2 bg-transparent uppercase">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
</Section>
