---
import ButtonLink from '@/components/ButtonLink.astro';
import Icon from '@/components/Icon.astro';
import type { HeroContent, ResumeContent } from '@/data/site-content.schema';

interface Props {
  content: HeroContent;
  resume: ResumeContent;
  resumeAvailable?: boolean;
}

const { content, resume, resumeAvailable = false } = Astro.props;
const socialIconFor = { github: 'github', linkedin: 'linkedin', mail: 'mail' } as const;
---

<section class="px-4 py-20 md:py-28">
  <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
    <div>
      <p class="eyebrow mb-4">{content.greeting}</p>
      <h1 class="max-w-4xl font-heading text-5xl font-semibold leading-[0.95] tracking-[-0.05em] text-text md:text-7xl">
        {content.name}
      </h1>
      <div class="mt-6 flex flex-wrap gap-2">
        {content.titles.map((title) => <span class="tag">{title}</span>)}
      </div>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-text-muted md:text-xl">
        {content.summary}
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <ButtonLink href={content.ctaHref} class="gap-2">
          {content.ctaLabel}
          <Icon name="arrow-down-right" size={17} />
        </ButtonLink>
        {resumeAvailable ? (
          <ButtonLink href={resume.href} variant="secondary" class="gap-2" download>
            {content.resumeLabel}
          </ButtonLink>
        ) : null}
      </div>
    </div>

    <aside class="panel p-6">
      <div class="flex items-start justify-between gap-6 border-b border-border pb-6">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted">Available for</p>
          <p class="mt-2 text-2xl font-semibold tracking-[-0.03em] text-text">Product engineering</p>
        </div>
        <div class="flex h-16 w-16 items-center justify-center border border-border bg-elevated font-mono text-xl font-semibold text-brand-primary">
          {content.initials}
        </div>
      </div>
      <p class="mt-6 text-sm leading-6 text-text-muted">{resume.note}</p>
      <div class="mt-6 flex gap-3">
        {content.socialLinks.map(({ platform, href, label }) => (
          <a href={href} aria-label={label} class="social-link">
            <Icon name={socialIconFor[platform]} size={18} />
          </a>
        ))}
      </div>
    </aside>
  </div>
</section>
