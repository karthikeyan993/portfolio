---
import type { HeroContent } from '@/data/site-content.schema';

interface Props {
  content: HeroContent;
}

const { content } = Astro.props;
---

<section class="pt-20 md:pt-32 pb-16 md:pb-24">
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <h1 class="display-hero text-brand-primary flex flex-col">
      <span>{content.name}</span>
      <span class="italic font-light">{content.titles[0]}</span>
    </h1>
    
    <div class="mt-16 md:mt-24 grid grid-cols-1 md:grid-cols-1 lg:grid-cols-[1fr_3fr] gap-8 md:gap-16">
      <div class="lg:col-start-2">
        <p class="max-w-2xl body-md text-text leading-relaxed">
          Building resilient systems and elegant interfaces. Currently crafting digital architectures with precision and intent.
        </p>
      </div>
    </div>
  </div>
</section>
