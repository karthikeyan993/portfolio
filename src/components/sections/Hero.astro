---
import type { HeroContent, ResumeContent } from '@/data/site-content.schema';
import ButtonLink from '@/components/ButtonLink.astro';
import Icon from '@/components/Icon.astro';
import ResumeDownloadLink from '@/components/ResumeDownloadLink.astro';
import Section from '@/components/Section.astro';

interface Props {
  content: HeroContent;
  resume: ResumeContent;
}

const { content, resume } = Astro.props;
const primaryTitle = content.titles[0];
const hasPrimaryCta = Boolean(content.ctaLabel.trim() && content.ctaHref.trim());
---

<Section spacing="hero" containerClass="max-w-7xl">
    {content.greeting ? <p class="eyebrow mb-6">{content.greeting}</p> : null}
    <h1 class="display-hero text-brand-primary flex flex-col">
      {content.name ? <span>{content.name}</span> : null}
      {primaryTitle ? <span class="italic font-light">{primaryTitle}</span> : null}
    </h1>
    
    <div class="mt-10 md:mt-12 max-w-2xl">
      {content.summary ? (
        <p class="max-w-2xl body-md text-text leading-relaxed">
          {content.summary}
        </p>
      ) : null}
      <div class="mt-8 flex flex-wrap items-center gap-3">
        {hasPrimaryCta ? (
          <ButtonLink href={content.ctaHref} class="gap-2">
            {content.ctaLabel}
            <Icon name="arrow-down-right" size={17} />
          </ButtonLink>
        ) : null}
        {resume.href && content.resumeLabel ? <ResumeDownloadLink resume={resume} label={content.resumeLabel} /> : null}
      </div>
    </div>
</Section>
