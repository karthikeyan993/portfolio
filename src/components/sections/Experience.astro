---
import type { ExperienceContent } from '@/data/site-content.schema';
import Section from '@/components/Section.astro';

interface Props {
  content: ExperienceContent;
  tinted?: boolean;
}

const { content } = Astro.props;
const items = content.items.filter((item) => item.company.trim() || item.role.trim() || item.period.trim());
---

<Section id="experience" containerClass="max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-16">
      <div class="md:col-span-4 md:pt-4">
        <h2 class="headline-md text-brand-primary">{content.eyebrow}</h2>
      </div>
      <div class="md:col-span-8 md:col-start-5">
        {items.map((experienceItem, i) => (
          <article class={`grid grid-cols-1 md:grid-cols-[10rem_1fr] gap-4 md:gap-8 py-6 first:pt-0 md:py-8 md:first:pt-8 ${i !== items.length - 1 ? 'border-b border-border' : ''}`}>
            <div>
              <p class="text-sm text-text-muted">{experienceItem.period.split(' - ').join(' — ')}</p>
            </div>
            <div>
              <h3 class="item-title text-brand-primary mb-2">{experienceItem.company}</h3>
              <p class="text-sm text-text-muted">{experienceItem.role}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
</Section>
