---
import ButtonLink from '@/components/ButtonLink.astro';
import Icon from '@/components/Icon.astro';
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import type { FeaturedProjectContent } from '@/data/site-content.schema';

interface Props {
  content: FeaturedProjectContent;
  tinted?: boolean;
}

const { content, tinted = false } = Astro.props;
---

<Section tinted={tinted}>
  <SectionHeading eyebrow={content.eyebrow} title={content.sectionTitle} />

  <article class="panel grid gap-8 p-6 md:grid-cols-[0.9fr_1.1fr] md:p-8">
    <div class="project-placeholder flex aspect-video items-center justify-center border border-border bg-elevated">
      <span class="font-mono text-6xl font-semibold text-text-muted/40">{content.title.charAt(0)}</span>
    </div>

    <div>
      <p class="eyebrow">{content.badge}</p>
      <h3 class="mt-3 font-heading text-3xl font-semibold tracking-[-0.04em] text-text">{content.title}</h3>
      <p class="mt-4 leading-7 text-text-muted">{content.summary}</p>

      <div class="mt-6 flex flex-wrap gap-2">
        {content.tags.map((tech) => <span class="tag">{tech}</span>)}
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        {content.links.live ? (
          <ButtonLink href={content.links.live} size="sm" class="gap-2">
            Live Demo <Icon name="external-link" size={15} />
          </ButtonLink>
        ) : null}
        {content.links.source ? (
          <ButtonLink href={content.links.source} variant="secondary" size="sm" class="gap-2">
            Source <Icon name="github" size={15} />
          </ButtonLink>
        ) : null}
      </div>
    </div>
  </article>
</Section>
