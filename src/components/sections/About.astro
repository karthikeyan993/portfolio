---
import type { AboutContent } from '@/data/site-content.schema';

interface Props {
  content: AboutContent;
}

const { content } = Astro.props;
---

<section id="about" class="py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 pt-4">
        <h2 class="headline-md text-brand-primary">{content.eyebrow}</h2>
        <p class="mt-2 text-sm italic text-text-muted">{content.title}</p>
      </div>
      <div class="md:col-span-7 md:col-start-6 pt-4 md:pt-12">
        <div class="space-y-8">
          {content.paragraphs.map((paragraph) => (
            <p class="body-md text-text leading-relaxed">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
