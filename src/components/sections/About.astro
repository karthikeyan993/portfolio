---
import Icon from '@/components/Icon.astro';
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import type { AboutContent } from '@/data/site-content.schema';

interface Props {
  content: AboutContent;
}

const { content } = Astro.props;
const iconFor = { user: 'user', mapPin: 'map-pin', languages: 'languages' } as const;
---

<Section id="about">
  <SectionHeading eyebrow={content.eyebrow} title={content.title} />

  <div class="grid gap-8 md:grid-cols-[1.1fr_0.9fr]">
    <div class="space-y-6 border-t border-border pt-6">
      {content.paragraphs.map((paragraph) => (
        <p class="max-w-3xl text-lg leading-8 text-text-muted">{paragraph}</p>
      ))}
    </div>

    <div class="grid gap-3">
      {content.highlights.map(({ icon, label, description }) => (
        <div class="panel flex items-start gap-4 p-5">
          <span class="icon-frame shrink-0"><Icon name={iconFor[icon]} size={18} /></span>
          <div>
            <p class="font-semibold text-text">{label}</p>
            <p class="mt-1 text-sm leading-6 text-text-muted">{description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</Section>
