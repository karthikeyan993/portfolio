---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'md' | 'sm';
  class?: string;
  download?: boolean | string;
}

const { href, variant = 'primary', size = 'md', class: className = '', download } = Astro.props;
const variantClasses = {
  primary: 'button-primary',
  secondary: 'button-secondary',
  ghost: 'button-ghost',
};
const sizeClasses = { md: '', sm: 'px-3 py-2 text-xs' };
---

<a href={href} class:list={[variantClasses[variant], sizeClasses[size], className]} download={download}>
  <slot />
</a>
