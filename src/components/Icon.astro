---
import ArrowDownRight from './icons/ArrowDownRight.astro';
import ArrowLeft from './icons/ArrowLeft.astro';
import ArrowUpRight from './icons/ArrowUpRight.astro';
import Briefcase from './icons/Briefcase.astro';
import Download from './icons/Download.astro';
import ExternalLink from './icons/ExternalLink.astro';
import Github from './icons/Github.astro';
import Languages from './icons/Languages.astro';
import Linkedin from './icons/Linkedin.astro';
import Mail from './icons/Mail.astro';
import MapPin from './icons/MapPin.astro';
import Menu from './icons/Menu.astro';
import Moon from './icons/Moon.astro';
import Send from './icons/Send.astro';
import Sun from './icons/Sun.astro';
import User from './icons/User.astro';
import X from './icons/X.astro';

const icons = {
  'arrow-down-right': ArrowDownRight,
  'arrow-left': ArrowLeft,
  'arrow-up-right': ArrowUpRight,
  'briefcase': Briefcase,
  'download': Download,
  'external-link': ExternalLink,
  'github': Github,
  'languages': Languages,
  'linkedin': Linkedin,
  'mail': Mail,
  'map-pin': MapPin,
  'menu': Menu,
  'moon': Moon,
  'send': Send,
  'sun': Sun,
  'user': User,
  'x': X,
} as const;

type IconName = keyof typeof icons;

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 18, class: className = '' } = Astro.props;
const Component = icons[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <Component />
</svg>
