---
interface Props {
  id?: string;
  class?: string;
  containerClass?: 'max-w-6xl' | 'max-w-7xl' | string;
  spacing?: 'default' | 'tight' | 'hero' | 'loose';
  tinted?: boolean;
}

const {
  id,
  class: className = '',
  containerClass = 'max-w-6xl',
  spacing = 'default',
  tinted = false,
} = Astro.props;

const spacingClass = {
  default: 'py-8 md:py-16',
  loose: 'py-12 md:py-24',
  hero: 'pt-16 md:pt-28 pb-8 md:pb-16',
  tight: 'py-8 md:py-12',
}[spacing];
---

<section id={id} class:list={[spacingClass, tinted && 'bg-elevated/45', className]}>
  <div class:list={['mx-auto px-4 md:px-8', containerClass]}>
    <slot />
  </div>
</section>
