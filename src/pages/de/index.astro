---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeLayout from '@/layouts/HomeLayout.astro';
import { getSiteContent } from '@/data/site-content';
import { getCollection } from 'astro:content';
import { getLatestPosts, filterPostsByLocale } from '@/lib/blog';

const content = getSiteContent('de');
const latestPosts = getLatestPosts(filterPostsByLocale(await getCollection('blog'), 'de'), 2);
---

<BaseLayout locale="de">
  <HomeLayout content={content} locale="de" posts={latestPosts} />
</BaseLayout>
