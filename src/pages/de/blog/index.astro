---
import { getCollection } from 'astro:content';
import BlogCard from '@/components/BlogCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSiteContent } from '@/data/site-content';
import { filterPublishedPosts, filterPostsByLocale, sortPostsByPublishedDate, getBlogPath } from '@/lib/blog';

const content = getSiteContent('de');
const posts = sortPostsByPublishedDate(filterPostsByLocale(filterPublishedPosts(await getCollection('blog')), 'de'));
const title = `Blog | ${content.hero.name}`;
const description = content.writing.description;
const alternatePaths = {
  en: getBlogPath('en'),
  de: getBlogPath('de'),
};
---

<BaseLayout title={title} description={description} locale="de" alternatePaths={alternatePaths}>
  <div class="mx-auto max-w-7xl px-4 md:px-8 pt-20 md:pt-32 pb-16 md:pb-24">
    <header class="mb-20 md:mb-32">
      <h1 class="display-hero text-brand-primary mb-6">{content.writing.title}</h1>
      <p class="body-lg text-text-muted max-w-2xl">{description}</p>
    </header>
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-8">
        {posts.length === 0 ? (
          <div class="py-8">
            <h2 class="headline-md text-brand-primary">{content.common.noPostsTitle}</h2>
            <p class="mt-2 text-text-muted">{content.common.noPostsDescription}</p>
          </div>
        ) : (
          <div class="space-y-16">
            {posts.map((post) => (
              <BlogCard post={post} locale="de" />
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
