---
import type { InferGetStaticPropsType } from 'astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import Prose from '@/components/Prose.astro';
import { getSiteContent } from '@/data/site-content';
import { filterPublishedPosts, filterPostsByLocale, formatPostDate, getBlogPath, getLanguageLabel, getReadingTime, sortPostsByPublishedDate, getPostAlternatePaths } from '@/lib/blog';
import { getHomeAnchor } from '@/lib/i18n';

export async function getStaticPaths() {
  const posts = sortPostsByPublishedDate(filterPostsByLocale(filterPublishedPosts(await getCollection('blog')), 'de'));

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const content = getSiteContent('de');
const { post } = Astro.props;
const { Content } = await render(post);
const title = `${post.data.title} | ${content.hero.name}`;
const blogPath = getBlogPath('de');
const contactPath = getHomeAnchor('contact', 'de');

const allPosts = await getCollection('blog');
const alternatePaths = getPostAlternatePaths(post, allPosts);
---

<BaseLayout
  title={title}
  description={post.data.description}
  image={post.data.cover?.src}
  ogType="article"
  publishedTime={post.data.publishedAt}
  updatedTime={post.data.updatedAt}
  tags={post.data.tags}
  locale="de"
  alternatePaths={alternatePaths}
>
  <article class="px-4 py-20 md:py-28">
    <div class="mx-auto max-w-3xl">
      <a href={blogPath} class="button-ghost mb-8 gap-2 px-0">
        <Icon name="arrow-left" size={16} /> {content.common.backToBlogLabel}
      </a>

      <header>
        <div class="flex flex-wrap items-center gap-2 text-sm text-text-muted">
          <time datetime={post.data.publishedAt.toISOString()}>{formatPostDate(post.data.publishedAt, 'de')}</time>
          <span aria-hidden="true">/</span>
          <span>{getReadingTime(post.body ?? '', content.common.readTimeSuffix)}</span>
          <span aria-hidden="true">/</span>
          <span class="tag">{getLanguageLabel(post.data.language)}</span>
          {post.data.updatedAt ? (
            <>
              <span aria-hidden="true">/</span>
              <span>{content.common.updatedLabel} {formatPostDate(post.data.updatedAt, 'de')}</span>
            </>
          ) : null}
        </div>

        <h1 class="mt-6 headline-xl text-brand-primary">
          {post.data.title}
        </h1>
        <p class="mt-6 body-lg text-text-muted">{post.data.description}</p>

        <div class="mt-8 flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      </header>

      {post.data.cover ? (
        <Image src={post.data.cover} alt={post.data.title} class="mt-10 w-full" />
      ) : null}

      <div class="mt-16">
        <Prose>
          <Content />
        </Prose>
      </div>

      <div class="mt-24 border-t border-border pt-8">
        <p class="headline-md text-brand-primary">{content.common.postContactTitle}</p>
        <p class="mt-2 body-md text-text-muted">
          {content.common.postContactDescription}
        </p>
        <a href={contactPath} class="mt-4 inline-flex label-caps text-brand-primary hover:text-text">{content.common.postContactCtaLabel}</a>
      </div>
    </div>
  </article>
</BaseLayout>
