---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeLayout from '@/layouts/HomeLayout.astro';
import { getCollection } from 'astro:content';
import { getSiteContent } from '@/data/site-content';
import { getLatestPosts, filterPostsByLocale } from '@/lib/blog';

const content = getSiteContent('en');
const latestPosts = getLatestPosts(filterPostsByLocale(await getCollection('blog'), 'en'), 2);
---

<BaseLayout enableLocaleRedirect>
  <HomeLayout content={content} locale="en" posts={latestPosts} />
</BaseLayout>
